# Copy to .env and fill in. Never commit .env.

# PostgreSQL + PostGIS connection string (used by the backend)
DATABASE_URL=postgresql+psycopg://el_service:el_service@localhost:5432/el_service

# Postgres credentials (used by infra/docker-compose.yml)
POSTGRES_USER=el_service
POSTGRES_PASSWORD=el_service
POSTGRES_DB=el_service

# Host port the DB is published on. Change to e.g. 5433 if 5432 is taken,
# and update the port in DATABASE_URL above to match.
POSTGRES_HOST_PORT=5432

# Extraction provider: local (Tesseract OCR, offline), ollama (free local
# vision model via Ollama, slow on CPU but context-aware), anthropic (Claude
# vision via the Messages API — best quality, needs a funded key).
EXTRACTION_PROVIDER=local

# Anthropic Messages API key (vision extraction, EXTRACTION_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# Vision-capable Claude model used for tour-plan extraction
EXTRACTION_MODEL=claude-haiku-4-5

# Ollama server + vision model (EXTRACTION_PROVIDER=ollama)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5vl:3b

# Tesseract languages (EXTRACTION_PROVIDER=local); "deu+eng" if the German
# pack is installed
OCR_LANGUAGES=eng

# Nominatim base URL used for geocoding
NOMINATIM_URL=https://nominatim.openstreetmap.org

# Overpass API endpoint used to look up opening hours (best-effort)
OVERPASS_URL=https://overpass-api.de/api/interpreter

# Routing engines (see infra/docker-compose.yml)
OSRM_URL=http://localhost:5000
VROOM_URL=http://localhost:3000

# Optimiser inputs
# Company base: every tour week departs from here on its first working day.
DEFAULT_START_LABEL=EL Service GmbH — Am Business Park
DEFAULT_START_STREET=Werner-Heisenberg-Straße 10
DEFAULT_START_POSTAL_CODE=52477
DEFAULT_START_CITY=Alsdorf
WORKING_DAY_START=07:00
WORKING_DAY_END=19:00
DEFAULT_SERVICE_MINUTES=60
# Weekday indices to skip (Mon=0 .. Sun=6); comma-separated. Default skips Sunday.
SKIP_WEEKDAYS=6
