# Copy to .env and fill in. Never commit .env.

# PostgreSQL + PostGIS connection string (used by the backend)
DATABASE_URL=postgresql+psycopg://el_service:el_service@localhost:5432/el_service

# Postgres credentials (used by infra/docker-compose.yml)
POSTGRES_USER=el_service
POSTGRES_PASSWORD=el_service
POSTGRES_DB=el_service

# Host port the DB is published on. Change to e.g. 5433 if 5432 is taken,
# and update the port in DATABASE_URL above to match.
POSTGRES_HOST_PORT=5432

# Anthropic Messages API key (vision extraction)
ANTHROPIC_API_KEY=

# Vision-capable Claude model used for tour-plan extraction
EXTRACTION_MODEL=claude-sonnet-5

# Nominatim base URL used for geocoding
NOMINATIM_URL=https://nominatim.openstreetmap.org

# Routing engines (see infra/docker-compose.yml)
OSRM_URL=http://localhost:5000
VROOM_URL=http://localhost:3000
