# Base URL of the FastAPI backend. On a physical phone in Expo Go this must be
# your machine's LAN IP (not localhost), e.g. http://192.168.1.20:8000.
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000

# Google Maps key for the Android map (react-native-maps). Read at prebuild /
# EAS build time — NOT a runtime EXPO_PUBLIC_ var. iOS uses Apple Maps, no key.
# Get one from https://console.cloud.google.com (enable "Maps SDK for Android").
GOOGLE_MAPS_ANDROID_API_KEY=
