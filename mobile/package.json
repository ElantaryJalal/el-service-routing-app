{
  "name": "el-service-mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "lint": "expo lint",
    "gen:api": "openapi-typescript \"${EXPO_PUBLIC_API_BASE_URL:-http://localhost:8000}/openapi.json\" -o src/api/types.ts"
  },
  "dependencies": {
    "@expo/metro-runtime": "~57.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@types/react": "~19.2.4",
    "expo": "^57.0.1",
    "expo-camera": "~57.0.0",
    "expo-constants": "~57.0.2",
    "expo-device": "~57.0.1",
    "expo-image-picker": "~57.0.1",
    "expo-linking": "~57.0.1",
    "expo-network": "~57.0.0",
    "expo-notifications": "~57.0.5",
    "expo-router": "~57.0.2",
    "expo-secure-store": "~57.0.0",
    "expo-sqlite": "~57.0.0",
    "expo-status-bar": "~57.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-maps": "1.27.2",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "^0.21.2",
    "typescript": "~6.0.3"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "eslint-config-expo": "~57.0.0",
    "openapi-typescript": "^7.13.0"
  }
